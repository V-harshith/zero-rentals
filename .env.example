# =============================================
# ZERORENTALS ENVIRONMENT VARIABLES
# =============================================
# This file serves as a template for .env.local
# DO NOT include real secrets in this file
# =============================================

# =============================================
# SUPABASE CONFIGURATION (Required)
# =============================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Only required for admin scripts, never verify/use in client code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================
# EMAIL SERVICE (Required for notifications)
# =============================================
# Option 1: Resend (Recommended)
RESEND_API_KEY=re_your_resend_api_key

# Option 2: SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email
# SMTP_PASSWORD=your_password

# Email Configuration
CONTACT_EMAIL=info@zerorentals.com
FROM_EMAIL=noreply@zerorentals.com

# =============================================
# GOOGLE MAPS API (Required for location features)
# =============================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# =============================================
# PAYMENT GATEWAY - RAZORPAY (Required for subscriptions)
# =============================================
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# =============================================
# APPLICATION SETTINGS
# =============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================
# SECURITY & AUTHENTICATION
# =============================================
# Admin email whitelist (comma-separated)
# Only these emails can be granted admin role during auto-profile creation
ADMIN_EMAILS=admin@zerorentals.com,owner@zerorentals.com

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=100
# CORS allowed origins
CORS_ORIGINS=http://localhost:3000,https://zerorentals.com

# =============================================
# FEATURE FLAGS (Optional)
# =============================================
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PAYMENT_GATEWAY=true
ENABLE_GOOGLE_MAPS=true
ENABLE_IMAGE_UPLOAD=true

# =============================================
# CRON JOB SECURITY (Required for production)
# =============================================
# Random secret to protect cron endpoints from unauthorized access
CRON_SECRET=your_random_cron_secret_key

# =============================================
# ADDITIONAL RAZORPAY SETTINGS
# =============================================
RAZORPAY_KEY_ID=rzp_test_your_key_id

# =============================================
# SITE URL (Production)
# =============================================
NEXT_PUBLIC_SITE_URL=https://zerorentals.vercel.app
